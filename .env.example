# Supabase - get values from Supabase Dashboard > Settings > API
# Copy this file to .env.local and fill in the values
# IMPORTANT: Wrong URL or anon key can cause the app to hang on load. Verify these are correct for your project.
#
# OpenAI - for hybrid search (query embeddings) and Edge Function (item embeddings)
OPENAI_API_KEY=
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# Phase 7: cron job must send x-cron-secret or Authorization: Bearer when calling /api/alerts/process-due
CRON_SECRET=

# Phase 9A/10A/11: Sentry (optional; enabled only in production when DSN set)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT=production  # Override; otherwise VERCEL_ENV / NODE_ENV used
# SENTRY_RELEASE=  # Override; otherwise VERCEL_GIT_COMMIT_SHA used
# SENTRY_AUTH_TOKEN=  # CI only, for source maps
# SENTRY_ORG=  # Required if using SENTRY_AUTH_TOKEN
# SENTRY_PROJECT=  # Required if using SENTRY_AUTH_TOKEN

# Phase 9A/10B: Upstash Redis for rate limiting and cron locks (when unset, permissive fallback)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# RATE_LIMIT_ENABLED=1  # Optional; 0 or false disables rate limiting

# Stripe Billing (Phase 08B)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=

# Phase 09B: Billing lifecycle
# Grace period in days when payment fails (default 7)
BILLING_GRACE_DAYS=7
# Comma-separated emails allowed to access /admin/billing
ADMIN_EMAILS=
# App URL for Stripe redirects (Vercel auto-sets VERCEL_URL; use NEXT_PUBLIC_APP_URL for explicit override)
NEXT_PUBLIC_APP_URL=

# SECURITY: SUPABASE_SERVICE_ROLE_KEY bypasses RLS. Use only in server-side code
# (Route Handlers, Server Actions, Server Components). NEVER import it in files
# that run in the browser (Client Components, middleware uses anon key only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase - get values from Supabase Dashboard > Settings > API
# Copy this file to .env.local and fill in the values
#
# OpenAI - for hybrid search (query embeddings) and Edge Function (item embeddings)
OPENAI_API_KEY=
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# Phase 7: cron job must send x-cron-secret or Authorization: Bearer when calling /api/alerts/process-due
CRON_SECRET=

# Phase 9A: Sentry (optional; enabled only in production when DSN set)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_AUTH_TOKEN=  # CI only, for source maps

# Phase 9A: Upstash Redis for distributed rate limiting (when unset, rate limiting disabled in dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Stripe Billing (Phase 08B)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
# App URL for Stripe redirects (Vercel auto-sets VERCEL_URL; use NEXT_PUBLIC_APP_URL for explicit override)
NEXT_PUBLIC_APP_URL=

# SECURITY: SUPABASE_SERVICE_ROLE_KEY bypasses RLS. Use only in server-side code
# (Route Handlers, Server Actions, Server Components). NEVER import it in files
# that run in the browser (Client Components, middleware uses anon key only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
